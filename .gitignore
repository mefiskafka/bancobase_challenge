__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.Python

# Virtualenvs
.venv/
venv/
env/

# Test / lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Notebooks
.ipynb_checkpoints/

# ─────────────────────────────────────────────────────────────────────────────
# Variables de entorno (no commitear secretos ni UIDs locales)
