.env
.env.*
!.env.example

# ─────────────────────────────────────────────────────────────────────────────
# Airflow — runtime artefactos (mantenemos la carpeta vacía con .gitkeep)
# ─────────────────────────────────────────────────────────────────────────────
ejercicio1/Airflow/logs/*
!ejercicio1/Airflow/logs/.gitkeep
ejercicio1/Airflow/dags/__pycache__/
ejercicio1/Airflow/plugins/__pycache__/
airflow.db
airflow-webserver.pid
standalone_admin_password.txt

# ─────────────────────────────────────────────────────────────────────────────
# MinIO — datos del object store (se regeneran en cada `docker compose up`)
# ─────────────────────────────────────────────────────────────────────────────
ejercicio1/Minio/data/*
!ejercicio1/Minio/data/.gitkeep

